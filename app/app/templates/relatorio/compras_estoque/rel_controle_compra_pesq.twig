{% set area = 'relatorios' %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/jquery/js/jquery.datatables1.10.19.js"></script>
    <script src="/assets/plugins/jquery/js/dataTables.bootstrap4.min.js"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v=14"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/js/select2.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/js/bootstrap-datepicker.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/locales/bootstrap-datepicker.pt-BR.min.js" charset="UTF-8"></script>
    <script src="/assets/js/local/rel_controle_compra_pesq.js?v=14"></script>
{% endblock %}
{% block title %}
     Relatório Controle de Compras
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <link href="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/css/select2.min.css" rel="stylesheet" />
    <link href='{{ base_url() }}/assets/plugins/datepicker/css/bootstrap-datepicker.min.css' rel='stylesheet'>
    <link href='{{ base_url() }}/assets/plugins/bootstrap/css/dataTables.bootstrap4.min.css' rel='stylesheet' type='text/css'>
    <link href="/assets/plugins/bootstrap-wizard/bootstrap.wizard.css" rel="stylesheet" type="text/css">
    <link href='/assets/plugins/daterangepicker/daterangepicker.css?v={{ JSversion }}' rel='stylesheet' type='text/css'>

{% endblock %}
{% block content %}
    <BR>
    <br>
    <br>
    <main class="content_wrapper">
        <div class="container">
            <div class="container col-md-12">
                <div class="row">
                    <div class="col-md-8">
                        &nbsp;
                    </div>
                </div>
                <div class="row ">
                    <div  tabindex="-1" role="dialog" aria-labelledby="modal-set-ramalLabel" >
                        <div class="col-lg" style="max-width:1245px;margin-left: auto;margin-right: auto;background-color: #F7F7F7;">
                            <div class="shadow-lg bg-white rounded mb-4" style="padding: 15px;background-color: #F7F7F7">
                                <div class="card-header" style="background-color: #F7F7F7">
                                    <div class="card-title col-sm-5">
                                        <h6 style= "color:#FF5403">Relatório Controle de Compras</h6>
                                    </div>
                                    <div class='col-sm-7' align="Right">
                                        <button type="button" class="btn btn-secondary btn-sm" id="cmdCancelar">Voltar</button>
                                        <button type="button" class="btn btn-primary btn-sm" id="cmdEnviar">Gerar Relatório</button>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            &nbsp;
                                        </div>
                                        <div class='col-md-4'>
                                            <label for='empresa_pk'>Empresa: </label>
                                            <select class='form-control form-control-sm chzn-select'  id='empresa_pk' name='empresa_pk'>
                                                <option></option>
                                            </select>
                                        </div>            
                                    </div>
                                    <br>
                                    <div class="row">
                                        <div class="col-md-4">
                                            &nbsp;
                                        </div>
                                        <div class='col-md-4'>
                                            <label for='fornecedor_pk'>Fornecedor: </label>
                                            <select type='text' class='form-control form-control-sm chzn-select'  id='fornecedor_pk' name='fornecedor_pk'>
                                                <option></option>
                                            </select>
                                        </div>            
                                    </div>
                                    <br>
                                    <div class="row">
                                        <div class="col-md-4">
                                            &nbsp;
                                        </div>
                                        <div class='col-md-4'>
                                            <label for='categoria_pk'>Categoria: </label>
                                            <select type='text' class='form-control form-control-sm chzn-select'  id='categoria_pk' name='categoria_pk'>
                                                <option></option>
                                            </select>
                                        </div>            
                                    </div>
                                    <br>
                                    <div class="row">
                                        <div class="col-md-4">
                                            &nbsp;
                                        </div>
                                        <div class='col-md-4'>
                                            <label for='tipo_grupo_centro_custo_pk'>Grupo de Centro de Custo: </label>
                                            <select class='form-control form-control-sm chzn-select'  id='tipo_grupo_centro_custo_pk' name='tipo_grupo_centro_custo_pk' />
                                                <option value=""></option>
                                                <option value="1">Leads (Clientes)</option>
                                                <option value="2">Colaboradores</option>
                                                <option value="3">Fornecedores</option>
                                            
                                            </select>
                                        </div>            
                                    </div>
                                    <br>
                                    <div class="row">
                                        <div class="col-md-4">
                                            &nbsp;
                                        </div>
                                        <div class='col-md-4'>
                                            <label for='vl_lancamento'>Centro de Custo: </label>
                                            <select class='form-control form-control-sm chzn-select'  id='grupo_lancamento_centro_custo_pk' name='grupo_lancamento_centro_custo_pk' >
                                                <option value=""></option>
                                            </select>
                                        </div>            
                                    </div>
                                    <br>
                                    <div class="row">
                                        <div class="col-md-4">
                                            &nbsp;
                                        </div>
                                        <div class="col-md-2">
                                            <label for="dt_ini_cad">Dt Ini Cad:&nbsp;</label>
                                            <input type='text' class='form-control form-control-sm' maxlength="10"  id='dt_ini_cad' name='dt_ini_cad' value="">                
                                        </div>
                                        <div class="col-md-2">
                                            <label for="dt_fim_cad">Dt Fim Cad:&nbsp;</label>
                                            <input type='text' class='form-control form-control-sm' maxlength="10"  id='dt_fim_cad' name='dt_fim_cad' value="">         
                                        </div>
                                    </div>
                                    <br>
                                    <div class="row">
                                        <div class="col-md-4">
                                            &nbsp;
                                        </div>
                                        <div class="col-md-2">
                                            <label for="dt_ini_compra">Dt Ini Compra:&nbsp;</label>
                                            <input type='text' class='form-control form-control-sm' maxlength="10"  id='dt_ini_compra' name='dt_ini_compra' value="">                
                                        </div>
                                        <div class="col-md-2">
                                            <label for="dt_fim_compra">Dt Fim Compra:&nbsp;</label>
                                            <input type='text' class='form-control form-control-sm' maxlength="10"  id='dt_fim_compra' name='dt_fim_compra' value="">         
                                        </div>
                                    </div>
                                    <br>
                                    <div class="row">                        
                                        <div class='col-md-4'>
                                            &nbsp;                                             
                                        </div>
                                        <div class='col-md-4'>
                                            <label for='ic_status'>Status:&nbsp;</label>
                                            <select class=" form-control form-control-sm chzn-select" id="ic_status" name="ic_status">
                                            <option></option>
                                            <option value="1">Em Processo de Compra</option>
                                            <option value="2">Compra Finalizada</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>   
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
