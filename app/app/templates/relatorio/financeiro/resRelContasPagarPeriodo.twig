
{% set area = 'relatorios' %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/jquery/js/jquery.datatables1.10.19.js"></script>
    <script src="/assets/plugins/jquery/js/dataTables.bootstrap4.min.js"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v=14"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/js/select2.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/js/bootstrap-datepicker.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/locales/bootstrap-datepicker.pt-BR.min.js" charset="UTF-8"></script>
    <script src="/assets/js/local/resRelContasPagarPeriodo.js?v=14"></script>
{% endblock %}
{% block title %}
        Relatório Contas a Pagar Período
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <link href="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/css/select2.min.css" rel="stylesheet" />
    <link href='{{ base_url() }}/assets/plugins/datepicker/css/bootstrap-datepicker.min.css' rel='stylesheet'>
    <link href='{{ base_url() }}/assets/plugins/bootstrap/css/dataTables.bootstrap4.min.css' rel='stylesheet' type='text/css'>
    <link href="/assets/plugins/bootstrap-wizard/bootstrap.wizard.css" rel="stylesheet" type="text/css">
    <link href='/assets/plugins/daterangepicker/daterangepicker.css?v={{ JSversion }}' rel='stylesheet' type='text/css'>
    <style>
    th{
            border: 1px solid black;
            padding: 8px;
            text-align: center;
        }
        .pulsing-text {
            font-size: 2em;
            color: #ff0000;
            text-align: center;
            margin-top: 20%;
            animation: pulse 1s infinite;
        }
    </style>
{% endblock %}
{% block content %}
<br><br><br><br>
    <main class="content_wrapper">
        <div class="container">
            <div class="container col-md-12">
                <div class="row">
                    <div class="col-md-8">
                        &nbsp;
                    </div>
                </div>
                <div class="row ">
                    <div  tabindex="-1" role="dialog" aria-labelledby="modal-set-ramalLabel" >
                        <div class="col-lg" style="max-width:1245px;margin-left: auto;margin-right: auto;background-color: #F7F7F7;">
                            <div class="shadow-lg bg-white rounded mb-4" style="padding: 15px;background-color: #F7F7F7">
                                <div class="card-header" style="background-color: #F7F7F7">
                                    <div class="card-title col-sm-5">
                                        <h6 style= "color:#FF5403"> Relatório Contas a Pagar Período</h6>
                                    </div>
                                    <div class='col-sm-7' align="Right">
                                        <button type="button" class="btn btn-secondary btn-sm" id="cmdCancelar">Voltar</button>
                                        <button type="button" class="btn btn-primary btn-sm" id="cmdExport">Export</button>
                                    </div>
                                </div>
                                <hr style='height:1px; border:none; color:#14074F; background-color:#14074F; margin-top: 0px; margin-bottom: 0px;'>
                                <br>
                                <div id='form'>
                                    <table>
                                        <tr>
                                            <td>
                                                <b>Relatório:</b>
                                            </td>
                                            <td>
                                                Contas a Pagar Período
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <b>Período:</b>
                                            </td>
                                            <td>
                                                <div>{{ dt_periodo }}</div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <b>Usuário Emissão:</b>
                                            </td>
                                            <td>
                                                <div>{{ session['session_user']['par2'] }}</div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <b>Empresa:</b>
                                            </td>
                                            <td>
                                            <div>{{ds_empresa}}</div>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td>
                                                <b>Grupo:</b>
                                            </td>
                                            <td>
                                            <div>{{ds_tipo_grupo}}</div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <b>Pago para:</b>
                                            </td>
                                            <td>
                                            <div>{{ds_grupo_leancamento}}</div>
                                            </td>
                                        </tr>
                                    </table>
                                    <br>
                                    <hr style='height:1px; border:none; color:#14074F; background-color:#14074F; margin-top: 0px; margin-bottom: 0px;'>
                                    <p>
                                    <div class="row">
                                        <div class="col-md-12">
                                        {% set total = 0 %}
                                        {% for itens in arrDados %}           
                                            <tr>
                                                <th colspan="4"><h3>{{itens['dt_vencimento']}}</h3></th>
                                            </tr>
                                            <table class="table table-striped  table-no-bordered display nowrap" style="width:100%">
                                                <thead style="background-color:#d3d3d3">
                                                    <tr>
                                                        <th style"width:25%;text-align:center">Grupo de Origem Lancamento</th>
                                                        <th style"width:25%;text-align:center">Pago Para</th>
                                                        <th style"width:25%;text-align:center">Plano de Conta</th>
                                                        <th style"width:25%;text-align:center">Valor</th>
                                                    </tr>
                                                </thead>
                                                <tbody style="background-color:white">
                                                    {% if itens['arrDados'] is defined %}
                                                        {% for dados in itens['arrDados'] %} 
                                                        <tr>
                                                            <th style"width:25%;text-align:center">{{dados['ds_tipo_grupo']}}</th>
                                                            <th style"width:25%;text-align:center">
                                                                {% if dados['ds_recebido']|length > 30 %}
                                                                    {{ dados['ds_recebido']|slice(0, 30) }}...
                                                                {% else %}
                                                                    {{ dados['ds_recebido'] }}
                                                                {% endif %}
                                                            </th>
                                                            <th style"width:25%;text-align:center">
                                                                {% if dados['ds_plano_contas']|length > 30 %}
                                                                    {{ dados['ds_plano_contas']|slice(0, 30) }}...
                                                                {% else %}
                                                                    {{ dados['ds_plano_contas'] }}
                                                                {% endif %}
                                                            </th>
                                                            <th style"width:25%;text-align:center">{{dados['vl_despesa']}}</th>
                                                        </tr>
                                                        
                                                        {% endfor %}
                                                    {% endif %}
                                                </tbody>
                                                <tfoot style="background-color:#d3d3d3">
                                                    <tr>
                                                        <th colspan="4" style="text-align:right">{{itens['vl_total_despesa_data']}}</th>
                                                        {% set total = total + itens['vl_total_despesa'] %}
                                                    </tr>
                                                    
                                                </tfoot>
                                            </table>
                                        {% endfor %}

                                        <tr>
                                            <div style="text-align:right"><h5>Total do Período:R$ {{ total|number_format(2, ',', '.') }}</h5></div>
                                        </tr>
                                        
                                        </div>
                                    </div>
                                </div>   
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

{% endblock %}