{% set area = 'administracao' %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/jquery/js/jquery.datatables1.10.19.js"></script>
    <script src="/assets/plugins/jquery/js/dataTables.bootstrap4.min.js"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v={{ JSversion }}"></script>
    <script src="/assets/js/local/auditoria_categoria_tipos_cad_form.js?v=14"></script>

    <script src="{{ base_url() }}/assets/plugins/datepicker/js/bootstrap-datepicker.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/locales/bootstrap-datepicker.pt-BR.min.js" charset="UTF-8"></script>
{% endblock %}
{% block title %}
    Benefício
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <link href='{{ base_url() }}/assets/plugins/datepicker/css/bootstrap-datepicker.min.css' rel='stylesheet'>
    <link href='{{ base_url() }}/assets/plugins/bootstrap/css/dataTables.bootstrap4.min.css' rel='stylesheet' type='text/css'>
    <link href="/assets/plugins/bootstrap-wizard/bootstrap.wizard.css" rel="stylesheet" type="text/css">
    <link href='/assets/plugins/daterangepicker/daterangepicker.css?v={{ JSversion }}' rel='stylesheet' type='text/css'>

{% endblock %}
{% block content %}
    <BR>
    <main class="main-content">
        <div class="container col" >
            <div class="container col-md-12">
                <div class="row">
                    <div class="col-md-8">
                        &nbsp;
                    </div>
                </div>
                
                <div class="row ">
                    <div>
                        <div class="col-lg" style="max-width:1245px;margin-left: auto;margin-right: auto;background-color: #F7F7F7;">
                            <div class="shadow-lg bg-white rounded mb-4" style="padding: 15px;">
                                <div class="card-header" style="background-color: #F7F7F7">
                                    <div class="card-title col-sm-4">
                                        <h5 style= "color:#FF5403" >Checklist Tipos Categorias</h5>
                                    </div>
                                    <div class='col-sm-8' align="Right">
                                        <button type="button" class="btn btn-secondary btn-sm" id="cmdCancelar">Voltar</button>
                                        &nbsp;
                                        <button type="button" class="btn btn-primary btn-sm" id="cmdEnviar">Salvar</button>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <input type="hidden" id='pk' name='pk' value='{{ pk }}'>
                                    <div class="tab_content">
                                        <div class='row'>
                                            <div class='col-md-4'>
                                                &nbsp;
                                            </div>
                                            <div class='col-md-4'>
                                                <label for='auditoria_categorias_pk'>Categoria Checklist:&nbsp;</label>
                                                <select class='form-control form-control-sm'  id='auditoria_categorias_pk' name='auditoria_categorias_pk' />
                                                    <option value=""></option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class='row'>
                                            <div class='col-md-4'>
                                                &nbsp;
                                            </div>
                                            <div class='col-md-4'>
                                                <label for='ds_auditoria_categoria_tipo'>Nome Checklist:&nbsp;</label>
                                                <input type='text' class='form-control form-control-sm' id='ds_auditoria_categoria_tipo' name='ds_auditoria_categoria_tipo' required >
                                            </div>
                                        </div>
                                        <div class='row'>
                                            <div class='col-md-4'>
                                                &nbsp;
                                            </div>
                                            <div class='col-md-4'>
                                                <label for="ds_colaborador">Posto de Trabalho:&nbsp;</label>
                                                <select class="form-control form-control-sm chzn-select" id="leads_pk" name="leads_pk">
                                                    <option></option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-4">
                                                &nbsp;
                                            </div>
                                            <div class='col-md-4'>
                                                <label for="ds_caonta">Função / Qualificação:&nbsp;</label>
                                                <select class='form-control form-control-sm chzn-select'  id='produtos_pk' name='produtos_pk' />
                                                <option></option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class='row'>
                                            <div class='col-md-4'>
                                                &nbsp;
                                            </div>
                                            <div class='col-md-4'>
                                                <label for='ic_status'>Status:&nbsp;</label>
                                                <select class='form-control form-control-sm'  id='ic_status' name='ic_status' />
                                                    <option value="1">Ativo</option>
                                                    <option value="2">Inativo</option>
                                                </select>
                                            </div>
                                        </div>
                                        <br>
                                        <div class='row'>
                                            <div class='col-md-4'>
                                                &nbsp;
                                            </div>
                                            <div class='col-md-4' align='center'>
                                                <button type="button" class="btn btn-primary btn-sm" id="cmdEnviarTiposCategoria">Adicionar Campos Checklist</button>
                                            </div>
                                        </div>

                                        <div class="container" id='container_campos_formulario'>
                                            <div class="card-title col-sm-4">
                                                <h5 style= "color:#FF5403" >Campos Checklist</h5>
                                            </div>
                                            <hr style='height:1px; border:none; color:#14074F; background-color:#14074F; margin-top: 0px; margin-bottom: 0px;'>
                                            <br>
                                            <form id="formCampos" class="formCampos">
                                                <input type='hidden'  id='auditorias_categorias_tipos_pk' name='auditorias_categorias_tipos_pk' />
                                                <div class='row'>
                                                    <div class='col-md-2'>
                                                        &nbsp;
                                                    </div>
                                                    <div class='col-md-3'>
                                                        <label for='tipo_item_pk'>Tipo Campo:&nbsp;</label>
                                                        <select class='form-control form-control-sm'  id='tipo_item_pk' name='tipo_item_pk' />
                                                            <option value=""></option>
                                                            <option value="1">Lista Suspensa</option>
                                                            <option value="2">Texto</option>
                                                            <option value="3">Checkbox</option>
                                                            <option value="4">Textearea</option>
                                                        </select>
                                                    </div>
                                                    <div class='col-md-3'>
                                                        <label for='ds_categoria_item'>Identificação do Campo:&nbsp;</label>
                                                        <input class='form-control form-control-sm'  id='ds_categoria_item' name='ds_categoria_item' />
                                                    </div>
                                                    <div class='col-md-2'>
                                                        <label for='ic_obrigatorio'>Obrigatório:&nbsp;</label>
                                                        <br>
                                                        <input type='checkbox' id='ic_obrigatorio' name='ic_obrigatorio' /> Sim
                                                    </div>
                                                </div>
                                                <br>
                                                <div class='row'>
                                                    <div class='col-md-4'>
                                                        &nbsp;
                                                    </div>
                                                    <div class='col-md-4' align='center'>
                                                        <button type="button" class="btn btn-primary btn-sm" id="cmdIncluir">Incluir Campo</button>
                                                    </div>
                                                </div>
                                                <div class='row'>
                                                    <div style="width:50%" id="campos_treeView">
                                                        
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-12" align="right">
                                                        <button type="button" class="btn btn-secondary btn-sm" id="cmdCancelar2">Voltar</button>
                                                        &nbsp;
                                                        <button type="button" class="btn btn-primary btn-sm" id="cmdEnviar2">Salvar</button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

{% endblock %}