Despesa

{% block JSfiles %}
    <script src="/assets/js/local/financeiro_grid_despesa.js?v=14"></script>
{% endblock %}

    <div class="row">
        <div class="col-md-12">
            <h6 class="font-weight-bold" style="color:#FF5403">Consulta de Despesa(s)</h6>
            <hr style='height:1px; border:none; margin-top: 0px; margin-bottom: 0px;'>
        </div>
    </div> 
    <br>
    <div class="row">
        <div class="col-md-4">
            &nbsp;
        </div>
        <div class="col-md-4">
            <div class="search-container">
                <div class="search-box">
                    <input type="text" class="search-input" id="buscaGeralDespesa" placeholder="Pesquisar...">
                    <i class="fas fa-search search-icon"></i>
                </div>
            </div>
        </div>
    </div>
    <br>
    <div class='row'>
        <div class="col-md-2">
            &nbsp;
        </div>
        <div class='col-md-2'>
            <label for='pk_lancamento_despesa'>Código:&nbsp;</label>
            <input type="text" class='form-control form-control-sm' id="pk_lancamento_despesa" name="pk_lancamento_despesa"/> 
        </div>
        <div class='col-md-2'>
            <label for='ic_status_pagamento_despesa'>Status:&nbsp;</label>
            <select class='form-control form-control-sm'  id='ic_status_pagamento_despesa' name='ic_status_pagamento_despesa' />
                <option value=""></option>
                <option value="1">Pago</option>
                <option value="2">Pendente</option>
                <option value="3">Aprovado</option>
                <option value="4">Atrasado</option>
                <option value="5">Cancelado</option>
            </select>  
        </div>
        <div class='col-md-2'>
            <label for='usuario_cadastro_despesa_pk'>Usuário Cadastro:&nbsp;</label>
            <select class='form-control form-control-sm'  id='usuario_cadastro_despesa_pk' name='usuario_cadastro_despesa_pk' />
                <option value=""></option>
            </select>  
        </div>
        <div class='col-md-2'>
            <label for='ds_lancamento_despesa'>Identificação do Lançamento:&nbsp;</label>
            <input type="text" class='form-control form-control-sm' id="ds_lancamento_despesa" name="ds_lancamento_despesa"/> 
        </div>    
    </div>
    <div class="row">
        <div class="col-md-2">
            &nbsp;
        </div>
        
        <div class='col-md-2'>
            <label for='ds_num_documento_despesa'>Identificação do Documento:&nbsp;</label>
            <input type="text" class='form-control form-control-sm' id="ds_num_documento_despesa" name="ds_num_documento_despesa"/> 
        </div>
        <div class='col-md-2'>
            <label for='ic_tipo_num_documento_despesa'>Tipo Documento:&nbsp;</label> 
            <select class='form-control form-control-sm'  id='ic_tipo_num_documento_despesa' name='ic_tipo_num_documento_despesa'>
                <option value=""></option>                               
                <option value="1">Num Boleto</option>
                <option value="2">Num NF</option>
            </select>
        </div>
        <div class='col-md-2'>
            <label for='empresa_despesa_pk'>Empresa:&nbsp;</label>
            <select class='form-control form-control-sm'  id='empresa_despesa_pk' name='empresa_despesa_pk'/>
                <option value=""></option>
            </select>  
        </div>
        <div class='col-md-2'>
            <label for='contas_despesa_pk'>Conta(s):&nbsp;</label>
            <select class='form-control form-control-sm'  id='contas_despesa_pk' name='contas_despesa_pk' />
                <option></option>
            </select>  
        </div>
        
        
                
    </div>
    <div class='row'>   
        <div class="col-md-2">
            &nbsp;
        </div>
        <div class='col-md-2'>
            <label for='tipo_grupo_despesa_pk'>GP Lançamento:&nbsp;</label>
            <select class='form-control form-control-sm'  id='tipo_grupo_despesa_pk' name='tipo_grupo_despesa_pk'/>
                <option value=""></option>
                <option value="1">Leads (Clientes)</option>
                <option value="2">Colaboradores</option>
                <option value="3">Fornecedores</option>
            </select>  
        </div>
        <div class='col-md-2'>
            <label for='grupo_lancamento_despesa_pk' class='recebido_de_pago_para'>Recebido de ? </label>
            <select class='form-control form-control-sm'  id='grupo_lancamento_despesa_pk' name='grupo_lancamento_despesa_pk'/>
                <option value=""></option>
            </select>  
        </div>    
        <div class='col-md-2'>
            <label for='ds_cpf_cnpj'>CPF/CNPJ</label>
            <select class='form-control form-control-sm' style='width:100%' id='ds_cpf_cnpj_despesa' name='ds_cpf_cnpj_despesa'/>
                <option value=""></option>
            </select>  
        </div> 
        <div class='col-md-2'>
            <label for='tipos_operacao_pk'>Tipo de Lançamento:&nbsp;</label>
            <select class='form-control form-control-sm'  style="width:100%"  id='tipo_lancamento_pk_despesa' name='tipo_lancamento_pk_despesa' requered>
                <option value=""></option>                               
                <option value="1">Receita</option>
                <option value="7">Custo Fixo</option>
                <option value="8">Custo Variável</option>
                <option value="2">Despesa Fixa</option>
                <option value="3">Despesa Variável</option>
                <option value="4">Imposto</option>
                <option value="5">Transferência</option>
                <option value="6" id="exibir_opc_caixinha">Caixinha</option>
            </select>  
        </div>                     
        
        
    </div>    
    <div class='row'>
        <div class="col-md-2">
            &nbsp;
        </div>
        <div class='col-md-2'>
            <label for='tipos_operacao_pk'>Categoria(s):&nbsp;</label>
            <select class='form-control form-control-sm' style="width:100%" id='categorias_financeiras_pk_despesa' name='categorias_financeiras_pk_despesa' requered>
                <option value=""></option>
            </select>  
        </div>
        <div class='col-md-2'>
            <label for='tipos_operacao_pk'>Planos Conta:&nbsp;</label>
            <select class='form-control form-control-sm' style="width:100%" id='tipos_operacao_pk_despesa' name='tipos_operacao_pk_despesa' requered/>
                <option value=""></option>
            </select>  
        </div>           
        
    </div>
    <div class='row'>
        <div class="col-md-2">
            &nbsp;
        </div>
        <div class="col-md-4" style="text-align:center">
            <label>Período Cadastro</label>
            <br>
            <div class="input-group">
                <input type="text" name="date_range_filter_cadastro_despesa"
                        class="form-control form-control-sm mask-date-hour" placeholder="Filtro por Data"
                        readonly="readonly" placeholder="Informe a data">
            </div>
        </div>
        <div class="col-md-4" style="text-align:center">
            <label>Período Faturamento</label>
            <br>
            <div class="input-group">
                <input type="text" name="date_range_filter_faturamento_despesa"
                        class="form-control form-control-sm mask-date-hour" placeholder="Filtro por Data"
                        readonly="readonly">
            </div>
        </div>                                       
    </div>
    <div class='row'>
        <div class="col-md-2">
            &nbsp;
        </div>
        <div class="col-md-4" style="text-align:center">
            <label>Período Vencimento</label>
            <br>
            <div class="input-group">
                <input type="text" name="date_range_filter_vencimento_despesa"
                        class="form-control form-control-sm mask-date-hour" placeholder="Filtro por Data"
                        readonly="readonly">
            </div>
        </div>                                       
        <div class="col-md-4" style="text-align:center">
            <label>Período Pagamento</label>
            <br>
            <div class="input-group">
                <input type="text" name="date_range_filter_pagamento_despesa"
                        class="form-control form-control-sm mask-date-hour" placeholder="Filtro por Data"
                        readonly="readonly">
            </div>
        </div>                                       
    </div>
    <br>
    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div id='draggable-events' align="center">

                <div class="draggable-event btn btn-block" style="border: 1px solid black;width: 200px; color:black">
                    <i class="fa fa-move"></i>Vencidos (R$)<br>
                    <span id="vencidosDespesa"></span>
                </div>

                <div class="draggable-event btn btn-block" style="border: 1px solid black;width: 250px; color:black">
                    <i class="fa fa-move"></i>Vencem Hoje (R$)<br>
                    <span id="vencidosHojeDespesa"></span>
                </div>

                <div class="draggable-event btn btn-block" style="border: 1px solid black;width: 250px; color:black">
                    <i class="fa fa-move"></i>A vencer (R$)<br>
                    <span id="aVencerDespesa"></span>
                </div>

                <div class="draggable-event btn btn-block" style="border: 1px solid black;width: 230px; color:black">
                    <i class="fa fa-move"></i>Recebidos (R$)<br>
                    <span id="recebidosDespesa"></span>
                </div>

                <div class="draggable-event btn btn-block" style="border: 1px solid black;width: 270px; color:black">
                    <i class="fa fa-move"></i>Total do Período (R$)<br>
                    <span id="valorTotalDespesa"></span>
                </div>
            </div>
        </div>
    </div>
    <br>
    <div class="row">
        
        <div class="col-md-12" align="center" >                
            <button type='button' class="btn btn-primary btn-sm" id='cmdPesqDespesa'>Buscar</button>    
        </div>
    </div> 
    <br>
    <div id='despesa'>
        <div class='overflow-auto' style='height:600px;overflow-y: scroll;' >
            <table class='table table-striped table-bordered ' style='width:100%' id='tblDespesa' >
                <thead style='position: sticky; top: 0px; background-color: white;'>
                    <tr>
                        <!--th width='5' align='center'><font style='font-size: 15px'><b>#</b></!--font>&nbsp;</th-->
                        <th align='center'><font style='font-size: 15px'><b>Identificação do Lançamento</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Dt. Cadastro</b></font></th>
                        <!--th align='center'><font style='font-size: 15px'><b>Usuário Cadastro</b></font></!--th-->
                        <th align='center'><font style='font-size: 15px'><b>Empresa</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Conta</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Dt. Faturamento</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Dt. Vencimento</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Dt. Pagamento</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Status</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Tipo</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Tipo Operação</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Grupo do Lançamento</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Recebido de/Pago Para</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>CPF/CNPJ</b></font></th>
                        <!--th align='center'><font style='font-size: 15px'><b>Metódo Pag.</b></font></!--th-->
                        <th align='center'><font style='font-size: 15px'><b>Vl. Lançamento</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Vl. Pendente</b></font></th>
                        <th align='center'><font style='font-size: 15px'><b>Ação</b></font></th>
                    </tr>
                </thead>
                <tfoot style='position: sticky; bottom: 0px; background-color: white;'>
                    <tr>
                        <td width='100' colspan=12 >&nbsp;</td>
                        <td width='100' ><b>Total R$<b/></td>
                        <td align='center' id='totalDespesaLancamento'></td>
                        <td align='center' id='totalDespesaPendente'></td>
                        <td align='center'>&nbsp;</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">        
            <hr>
        </div>
    </div>
</div>
