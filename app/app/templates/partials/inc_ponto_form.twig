{% block JSfiles %}
    <script src="/assets/js/local/inc_ponto_form.js?v=14"></script>
{% endblock %}
{% block content %}
    <BR>
    <main class="main-content">
        <div class="container">
            <div class="row">
                <div class="col-lg-6">
                    <div class="modal fade bd-example-modal-lg" id="janela_ponto">
                        <div class="modal-dialog modal-lg" role="document">
                            <div class="modal-content" >
                                <div class="modal-header">
                                    <h6 style= "color:#FF5403">
                                        Registro de Ponto <span id="date"></span>
                                    </h6>
                                </div>
                                <form id="form_colaborador">
                                    <div class="card-body py-3">
                                        <div class='col-md-3'> &nbsp; </div>        
                                        <div id="message" class="mt-6"></div>     
                                        <table class="table table-striped table-no-bordered display nowrap" style="width:100%" id="tblListarPontoDia">
                                            <thead>
                                                <th>#</th>
                                                <th>Data Cadastro</th>
                                                <th>Hora</th>
                                                <th>Tipo Apontamento</th>
                                                <th>Usuário de Cadastro</th>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>                 
                                        <br>
                                    </div>	
                                </form>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" id="cmdFecharPonto" data-dismiss="modal">Fechar</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}