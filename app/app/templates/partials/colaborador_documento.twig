<style>
    /* Estilo para a impressão */
    @media print {
        .noprint {
            display: none;
        }
        @page {
            size: A4;
            margin: 10mm;
        }
        #printableAreaRelogio {
            width: 100%;
            font-size: 12pt;
            overflow: hidden;
            page-break-inside: avoid;
        }
        #printableAreaRelogio img {
            max-width: 100%;
            height: auto;
        }
        .row {
            display: flex;
            flex-wrap: wrap;
        }
        .col-md-4, .col-md-12 {
            width: 100%;
            margin-bottom: 10px;
        }
        .modal-header div {
            display: none;
        }
    }

    /* Ajuste o modal para ocupar toda a largura da tela */
    .modal-fullscreen {
        width: 100vw;
        max-width: 100%;
        margin: 0;
    }
    .modal-fullscreen .modal-dialog {
        width: 100%;
        max-width: none;
        margin: 0;
    }
    .modal-fullscreen .modal-content {
        width: 100%;
        max-width: none;
    }
</style>



