{% block JSfiles %}
    <script src="/assets/js/local/financeiro_grid_lancamento.js?v=14"></script>
{% endblock %}

<div class="row">
    <div class="col-md-12">
        <h6 class="font-weight-bold" style="color:#FF5403">Consulta de Lançamento(s)</h6>
        <hr style='height:1px; border:none; margin-top: 0px; margin-bottom: 0px;'>
    </div>
</div> 
<br>
<div class="row">
    <div class="col-md-4">
        &nbsp;
    </div>
    <div class="col-md-4">
        <div class="search-container">
            <div class="search-box">
                <input type="text" class="search-input" id="buscaGeralLancamento" placeholder="Pesquisar...">
                <i class="fas fa-search search-icon"></i>
            </div>
        </div>
    </div>
</div>
<br>
<div class='row'>
    <div class="col-md-2">
        &nbsp;
    </div>
    <div class='col-md-2'>
        <label for='vl_lancamento'>Código:&nbsp;</label>
        <input type="text" class='form-control form-control-sm' id="pk_lancamento_lancamento" name="pk_lancamento_lancamento"/> 
    </div>
    <div class='col-md-2'>
        <label for='tipos_operacao_pk'>Status:&nbsp;</label>
        <select class='form-control form-control-sm'  id='ic_status_pagamento_lancamento' name='ic_status_pagamento_lancamento' />
            <option value=""></option>
            <option value="1">Pago</option>
            <option value="2">Pendente</option>
            <option value="3">Aprovado</option>
            <option value="4">Atrasado</option>
            <option value="5">Cancelado</option>
        </select>  
    </div>
    <div class='col-md-2'>
        <label for='tipos_operacao_pk'>Usuário Cadastro:&nbsp;</label>
        <select class='form-control form-control-sm'  id='usuario_cadastro_lancamento_pk' name='usuario_cadastro_lancamento_pk' />
            <option value=""></option>
        </select>  
    </div>
    <div class='col-md-2'>
        <label for='ds_lancamento_lancamento'>ID do Lançamento:&nbsp;</label>
        <input type="text" class='form-control form-control-sm' id="ds_lancamento_lancamento" name="ds_lancamento_lancamento"/> 
    </div>
</div>
<div class='row'> 
    <div class="col-md-2">
        &nbsp;
    </div>
    
    <div class='col-md-2'>
        <label for='ds_num_documento_lancamento'>ID do Documento:&nbsp;</label>
        <input type="text" class='form-control form-control-sm' id="ds_num_documento_lancamento" name="ds_num_documento_lancamento"/> 
    </div>
    <div class='col-md-2'>
        <label for='ic_tipo_num_documento_lancamento'>Tipo do Documento:&nbsp;</label> 
        <select class='form-control form-control-sm'  id='ic_tipo_num_documento_lancamento' name='ic_tipo_num_documento_lancamento'>
            <option value=""></option>                               
            <option value="1">Num Boleto</option>
            <option value="2">Num NF</option>
        </select>
    </div>
    <div class='col-md-2'>
        <label for='tipos_operacao_pk'>Empresa:&nbsp;</label>
        <select class='form-control form-control-sm'  id='empresa_pk' name='empresa_pk'/>
            <option value=""></option>
        </select>  
    </div>
    <div class='col-md-2'>
        <label for='bancos_pk'>Conta(s):&nbsp;</label>
        <select class='form-control form-control-sm'  id='contas_lancamento_pk' name='contas_lancamento_pk' />
            <option></option>
        </select>  
    </div>
</div> 
<div class="row">
    <div class="col-md-2">
        &nbsp;
    </div>
    <div class='col-md-2'>
        <label for='tipo_grupo_pk'>GP Origem Lançamento:&nbsp;</label>
        <select class='form-control form-control-sm'  id='tipo_grupo_lancamento_pk' name='tipo_grupo_lancamento_pk'/>
            <option value=""></option>
            <option value="1">Leads (Clientes)</option>
            <option value="2">Colaboradores</option>
            <option value="3">Fornecedores</option>
        </select>  
    </div>
    <div class='col-md-2'>
        <label for='vl_lancamento' class='recebido_de_pago_para'>Recebido de ? </label>
        <select class='form-control form-control-sm'  id='grupo_grid_lancamento_pk' name='grupo_grid_lancamento_pk'/>
            <option value=""></option>
        </select>  
    </div> 
    <div class='col-md-2'>
        <label for='ds_cpf_cnpj'>CPF/CNPJ</label>
        <select class='form-control form-control-sm' style='width:100%' id='ds_cpf_cnpj_lancamento' name='ds_cpf_cnpj_lancamento'/>
            <option value=""></option>
        </select>  
    </div>    
    <div class='col-md-2'>
        <label for='tipos_operacao_pk'>Tipo de Lançamento:&nbsp;</label>
        <select class='form-control form-control-sm'  style="width:100%"  id='tipo_lancamento_pk_lancamento' name='tipo_lancamento_pk_lancamento' requered>
            <option value=""></option>                               
            <option value="1">Receita</option>
            <option value="7">Custo Fixo</option>
            <option value="8">Custo Variável</option>
            <option value="2">Despesa Fixa</option>
            <option value="3">Despesa Variável</option>
            <option value="4">Imposto</option>
            <option value="5">Transferência</option>
            <option value="6" id="exibir_opc_caixinha">Caixinha</option>
        </select>  
    </div>          
</div>
<div class='row'>   
    <div class="col-md-2">
        &nbsp;
    </div>
                       
    <div class='col-md-2'>
        <label for='tipos_operacao_pk'>Categoria(s):&nbsp;</label>
        <select class='form-control form-control-sm' style="width:100%" id='categorias_financeiras_pk_lancamento' name='categorias_financeiras_pk_lancamento' requered>
            <option value=""></option>
        </select>  
    </div>
    <div class='col-md-2'>
        <label for='tipos_operacao_pk'>Planos Conta:&nbsp;</label>
        <select class='form-control form-control-sm' style="width:100%" id='tipos_operacao_pk_lancamento' name='tipos_operacao_pk_lancamento' requered/>
            <option value=""></option>
        </select>  
    </div>
</div>
<div class='row'>
    <div class="col-md-2">
        &nbsp;
    </div>
    <div class="col-md-4" style="text-align:center">
        <label>Período Cadastro</label>
        <br>
        <div class="input-group">
            <input type="text" name="date_range_filter_cadastro"
                    class="form-control form-control-sm mask-date-hour" placeholder="Filtro por Data"
                    readonly="readonly" placeholder="Informe a data">
        </div>
    </div>
    <div class="col-md-4" style="text-align:center">
        <label>Período Faturamento</label>
        <br>
        <div class="input-group">
            <input type="text" name="date_range_filter_faturamento"
                    class="form-control form-control-sm mask-date-hour" placeholder="Filtro por Data"
                    readonly="readonly">
        </div>
    </div>                                       
</div>
<div class='row'>
    <div class="col-md-2">
        &nbsp;
    </div>
    <div class="col-md-4" style="text-align:center">
        <label>Período Vencimento</label>
        <br>
        <div class="input-group">
            <input type="text" name="date_range_filter_vencimento"
                    class="form-control form-control-sm mask-date-hour" placeholder="Filtro por Data"
                    readonly="readonly">
        </div>
    </div>                                       
    <div class="col-md-4" style="text-align:center">
        <label>Período Pagamento</label>
        <br>
        <div class="input-group">
            <input type="text" name="date_range_filter_pagamento"
                    class="form-control form-control-sm mask-date-hour" placeholder="Filtro por Data"
                    readonly="readonly">
        </div>
    </div>                                       
</div>

<br>
<div class="row">
    
    <div class="col-md-12" align="center" >                
        <button type='button'  class="btn btn-primary btn-md" id='cmdPesqLancamento'>Buscar</button>    
    </div>
</div>
<br>
<div id='lancamento'>
    <div class='overflow-auto' style='height:1300px;overflow-y: scroll;' >
        <table class='table table-striped table-bordered ' style='width:100%' id='tblLancamento' >
            <thead style='position: sticky; top: 0px; background-color: white;'>
                <tr>
                    <!--th width='5' align='center'><font style='font-size: 15px'><b>#</b></!--font>&nbsp;</th-->
                    <th align='center'><font style='font-size: 15px'><b>Cód</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Status</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Tipo</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Identificação do Lançamento</b></font></th>
                    
                    <!--th align='center'><font style='font-size: 15px'><b>Usuário Cadastro</b></font></!--th-->
                    <th align='center'><font style='font-size: 15px'><b>Empresa</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Conta</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Dt. Vencimento</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Dt. Pagamento</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Recebido de/Pago Para</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>CPF/CNPJ</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Vl. Lançamento</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Vl. Pendente</b></font></th>
                    
                    <th align='center'><font style='font-size: 15px'><b>Ação</b></font></th>
                </tr>
            </thead>
            <tfoot style='position: sticky; bottom: 0px; background-color: white;'>
                <tr>
                    <td width='100' colspan=9 >&nbsp;</td>
                    <td width='100' ><b>Total R$<b/></td>
                    <td align='center' id='totalLancamento'></td>
                    <td align='center' id='totalLancamentoPendente'></td>
                    <td align='center'>&nbsp;</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div> 