{% if local == 2%}
    {% set area = 'operacional' %}
{% else %}
    {% set area = 'comercial' %}
{% endif %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/jquery/js/jquery.datatables1.10.19.js"></script>
    <script src="/assets/plugins/jquery/js/dataTables.bootstrap4.min.js"></script>
    <script src="/assets/js/local/qrCode.js?v=14"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v={{ JSversion }}"></script>
    <script src="https://cdn.jsdelivr.net/npm/qrcode-generator/qrcode.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>

{% endblock %}
{% block title %}
     QrCode
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <link href='{{ base_url() }}/assets/plugins/bootstrap/css/dataTables.bootstrap4.min.css' rel='stylesheet' type='text/css'>
    <link href="/assets/plugins/bootstrap-wizard/bootstrap.wizard.css" rel="stylesheet" type="text/css">
    <link href='/assets/plugins/daterangepicker/daterangepicker.css?v={{ JSversion }}' rel='stylesheet' type='text/css'>

{% endblock %}
{% block content %}
    <BR>
    <main class="main-content">
        <div id="container-fluid">
            <div id="container col-sm-12">
                <div id="noprint">
                    <br>
                    <div class="row">
                        <div class="col-md-12" align="center" >
                            <input type="hidden" id="pk" value="{{ pk }}">
                            <button type="button" class="btn btn-secondary" id="cmdVoltar" data-dismiss="modal">Voltar</button>&nbsp;&nbsp;&nbsp;
                            <button type="button" class="btn btn-primary" id="cmdSalvar" data-dismiss="modal">Salvar</button>
                            <button type="button" class="btn btn-primary" style="background-color:green" id="cmdImprimir" data-dismiss="modal">Gerar PDF</button>&nbsp;&nbsp;&nbsp;
                        </div>
                    </div>
                    <br>
                    <div>
                        <div class='row'>
                                <div class='col-md-12' align='center'>
                                    <h4>QR Code Colaboradores</h4>
                                </div>
                            </div>
                            <div class='row'>
                                <div class="col-md-3">
                                    &nbsp;
                                </div>
                                <div class='col-md-9'>
                                    <label><b> Posto de Trabalho:</b> </label>
                                    <input type="hidden" id="leads_pk" value="{{pk}}">
                                    <input type="hidden" id="ds_lead" value="{{ds_lead}}">
                                    <span id='ds_lead_qr_code'>{{ds_lead}}</span>
                                </div>
                            </div>
                        </div>
                        <br>
                        
                        <div class="row" >
                            <div class="col-md-2">
                            
                            </div>
                            <div class="col-md-8">
                                    <button type='button' class="btn btn-primary" id='cmdIncluirLinha'>Incluir Linha</button>
                            </div>
                        </div>
                        <div class="row" >
                            <div class="col-md-2">
                            
                            </div>
                            <div class="col-md-8">
                                <table class="table table-striped table-bordered nowrap" style="width:100%" id="tblGrid">
                                    <thead>
                                    <tr>
                                        <th>Descrição Local Ponto</th>
                                        <th>Ação</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <br>
                    <br>
                </div>
                <div id="printableArea">
                    <span id="qrcode-container"></span>
                </div>
            </div>    
        </div>
    </main>
{% endblock %}