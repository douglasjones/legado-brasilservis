{% set area = 'financeiro' %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/jquery/js/jquery.datatables1.10.19.js"></script>
    <script src="/assets/plugins/jquery/js/dataTables.bootstrap4.min.js"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v={{ JSversion }}"></script>

    <script src="{{ base_url() }}/assets/plugins/datepicker/js/bootstrap-datepicker.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/locales/bootstrap-datepicker.pt-BR.min.js" charset="UTF-8"></script>
    <script src="/assets/js/local/faturamento_emissoes_res_form.js?v=14"></script>
{% endblock %}
{% block title %}
    Financeiro
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <link href='{{ base_url() }}/assets/plugins/datepicker/css/bootstrap-datepicker.min.css' rel='stylesheet'>
    <link href='{{ base_url() }}/assets/plugins/bootstrap/css/dataTables.bootstrap4.min.css' rel='stylesheet' type='text/css'>
    <link href='{{ base_url() }}/assets/css/pages/settings-selectables.css' rel='stylesheet' type='text/css'>
    <link href="/assets/plugins/bootstrap-wizard/bootstrap.wizard.css" rel="stylesheet" type="text/css">
    <link href='/assets/plugins/daterangepicker/daterangepicker.css?v={{ JSversion }}' rel='stylesheet' type='text/css'>

{% endblock %}
{% block content %}
    <br>
    <main class="main-content">
        <div class="row">
            <div class="col-md-8">
                &nbsp;
            </div>
        </div>
        <p>
        <div class="card shadow"  style="margin:12px" >
            <div class="card-header">
                <div class='col-md-6' align="left">
                    <h5 class="font-weight-bold" style= "color:#FF5403" >Faturamento - Lançamentos</h5>
                </div>
                <div class='col-md-6' align="Right">
                    <button type="button" class="btn btn-secondary btn-sm" id="cmdVoltar">Voltar</button>
                </div>
            </div>
        </div>
        <br>
        <div id="DadosFaturamento">    
            <div class="row">
                <div class="col-11">
                    <input type="hidden" id='pk' value="{{ pk }}">
                    <div class="col-md-12" style="margin-left:60px">
                        <table class="table table-striped table-no-bordered" style="width:100%" id="tblResultado">
                            <thead>
                                <tr>
                                    <th >
                                        <input style="width: 150px;" class="form-control form-control-sm" type='text' id='txtCodLancamento' placeholder='Pesquisar por'/>
                                    </th>
                                    <th >
                                        <input style="width: 150px;" class="form-control form-control-sm" type='text' id='txtClientePostoTrabalho' placeholder='Pesquisar por'/>
                                    </th>
                                    <th>
                                        <input style="width: 150px;" class="form-control form-control-sm" type='text' id='txtPeriodoFaturamento' placeholder='Pesquisar por'/>
                                    </th>
                                    <th>
                                        <input style="width: 150px;" class="form-control form-control-sm" type='text' id='txtVlFaturamento' placeholder='Pesquisar por'/>
                                    </th>
                                    <th>
                                        <input style="width: 150px;" class="form-control form-control-sm" type='text' id='txtStatusFaturamento' placeholder='Pesquisar por'/>
                                    </th>
                                    <th>
                                        <input style="width: 150px;" class="form-control form-control-sm" type='text' id='txtStatusLancamento' placeholder='Pesquisar por'/>  
                                    </th> 
                                    <!--th>
                                        <input style="width: 150px;" class="form-control form-control-sm"  type='text' id='txtCodNotaFiscal' placeholder='Pesquisar por'/>
                                    </th-->
                                    
                                </tr>
                                <tr>              
                                    <th>Cód. Lancamento</th>                    
                                    <th>Cliente / Posto</th>
                                    <th>Período de Faturamento</th>
                                    <th>Vl. Faturamento</th>
                                    <th>Status Faturamento</th>
                                    <th>Status Lançamento</th>
                                    <!--th>Cód Nota Fiscal</th-->
                                </tr>
                            </thead>
                        </table>
                    </div>
                </div>    
            </div>    
        </div>
        <br>
        <br>
        <br>
    </main>

{% endblock %}