{% set area = 'administracao' %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/js/local/equipe_cad_form.js?v=14"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v={{ JSversion }}"></script>
{% endblock %}
{% block title %}
    Equipes
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <link href='{{ base_url() }}/assets/css/local/receptivo.css' rel='stylesheet' type='text/css'>
    <link href="/assets/plugins/bootstrap-wizard/bootstrap.wizard.css" rel="stylesheet" type="text/css">
    <link href='/assets/plugins/daterangepicker/daterangepicker.css?v={{ JSversion }}' rel='stylesheet' type='text/css'>

{% endblock %}
{% block content %}
    <BR>
    <main class="main-content">  
        <div class="container">
            <div class="container col-md-12">
                <div class="row">
                    <div class="col-md-8">
                        &nbsp;
                    </div>
                </div>
                <div class="row ">
                    <div  tabindex="-1" role="dialog" aria-labelledby="modal-set-ramalLabel" >
                        <div class="col-lg" style="max-width:1245px;margin-left: auto;margin-right: auto;background-color: #F7F7F7;">
                            <form id="form" class="form">
                                <div class="shadow-lg bg-white rounded mb-4" style="padding: 15px;background-color: #F7F7F7">
                                    <div class="card-header" style="background-color: #F7F7F7">
                                        <div class="card-title col-sm-4">
                                            <h5 style= "color:#FF5403"  >Centro de Custos:</h5>
                                        </div>
                                        <div class='col-sm-8' align="Right">
                                            <button type="button" class="btn btn-secondary btn-sm" id="cmdCancelar">Voltar</button>
                                            <button type="submit" class="btn btn-primary btn-sm" id="cmdEnviar">Salvar</button>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                    <input type="hidden" id="pk" name="pk" value="{{pk}}">
                                        <div class='row'>
                                            <div class='col-md-4'>
                                                &nbsp;
                                            </div>
                                            <div class='col-md-4'>
                                                <label for="ds_equipe">Centro de Custos:&nbsp;</label>
                                                <input type="text" class="form-control form-control-sm" id="ds_equipe" name="ds_equipe" required="true">
                                            </div>
                                        </div>
                                        <p>
                                        <div class='row'>
                                            <div class='col-md-12' align="center">
                                                <button type="button" class="btn-sm btn-primary" id="cmdIncluir" name="cmdIncluir">Incluir Usuário</button>
                                            </div>
                                        </div>
                                        <br>
                                        <br>
                                        <hr style='height:1px; border:none; color:#14074F; background-color:#14074F; margin-top: 0px; margin-bottom: 0px;'>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <table class="table table-striped table-no-bordered  nowrap" style="width:100%" id="tblUsuario">
                                                    <thead>
                                                            <th>Usuário</th>
                                                            <th>Gerente</th>
                                                            <th>Supervisor</th>
                                                            <th width="1%">Ação</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}


