{% set area = 'financeiro' %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/jquery/js/jquery.datatables1.10.19.js"></script>
    <script src="/assets/plugins/jquery/js/dataTables.bootstrap4.min.js"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v=14"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/js/select2.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/js/bootstrap-datepicker.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/locales/bootstrap-datepicker.pt-BR.min.js" charset="UTF-8"></script>
    <script src="/assets/js/local/financeiro_usuario_lancamento_res_form.js?v=14"></script>
    <script src="/assets/js/local/financeiro_documento_historico_res_form.js?v=14"></script>
    <script src="/assets/js/local/financeiro_documento_cad_form.js?v=14"></script>
{% endblock %}
{% block title %}
    Financeiro
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <link href="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/css/select2.min.css" rel="stylesheet" />
    <link href='{{ base_url() }}/assets/plugins/datepicker/css/bootstrap-datepicker.min.css' rel='stylesheet'>
    <link href='{{ base_url() }}/assets/plugins/bootstrap/css/dataTables.bootstrap4.min.css' rel='stylesheet' type='text/css'>
    <link href='{{ base_url() }}/assets/css/pages/settings-selectables.css' rel='stylesheet' type='text/css'>
    <link href="/assets/plugins/bootstrap-wizard/bootstrap.wizard.css" rel="stylesheet" type="text/css">
    <link href='/assets/plugins/daterangepicker/daterangepicker.css?v={{ JSversion }}' rel='stylesheet' type='text/css'>
{% endblock %}
{% block content %}
<main class="main-content">
    <div class="row">
        <div class="col-md-8">
            &nbsp;
        </div>
    </div>
    <div class="card shadow"  style="margin:12px" >
        <div class="card-header">
            <div class='col-md-7' align='left'>
                <h5 class="font-weight-bold" style= "color:#FF5403"  >Controle Lançamento(s) Financeiro</h5>
            </div>
            <div class='col-md-5' align='right'>
                <button class='btn btn-secondary btn-sm' id='cmdVoltar'>Voltar</button>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                &nbsp;
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class='row'>
                        <div class='col-sm-2'>
                            <button type='button' class="btn btn-primary btn-sm" id='cmdNovoLancamento'>Novo Lançamento</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-8">
                    &nbsp;
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <h4>Consultar Lançamento(s) </h4>
                    <hr style='height:1px; border:none; color:#14074F; background-color:#14074F; margin-top: 0px; margin-bottom: 0px;'>
                </div>
            </div>
            <div class="row">
                <div class="col-md-8">
                    &nbsp;
                </div>
            </div>
            <div class='row'>
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento'>Código:&nbsp;</label>
                    <input type="text" class='form-control form-control-sm' id="pk_lancamento_lancamento_pesq" name="pk_lancamento_lancamento_pesq"/>
                    <input type="hidden" class='form-control form-control-sm' id="usuario_pk" name="usuario_pk" value='{{ session['session_user']['par1'] }}'>
                </div>
                <div class='col-md-2'>
                    <label for='tipos_operacao_pk'>Status:&nbsp;</label>
                    <select class='form-control form-control-sm'  id='ic_status_pagamento_lancamento_pesq' name='ic_status_pagamento_lancamento_pesq' />
                    <option value=""></option>
                    <option value="1">Pago</option>
                    <option value="2">Pendente</option>
                    <option value="3">Aprovado</option>
                    <option value="4">Atrasado</option>
                    <option value="5">Cancelado</option>
                    </select>
                </div>
                <div class='col-md-2'>
                    <label for='tipos_operacao_pk'>Usuário Cadastro:&nbsp;</label>
                    <select class='form-control form-control-sm'  id='usuario_cadastro_lancamento_pk_pesq' name='usuario_cadastro_lancamento_pk_pesq' />
                    <option value=""></option>
                    </select>
                </div>
            </div>
            <div class='row'>
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-2'>
                    <label for='ds_num_documento_gridUsuario'>Identificação do Documento:&nbsp;</label>
                    <input type="text" class='form-control form-control-sm' id="ds_num_documento_pesq" name="ds_num_documento_pesq"/>
                </div>
                <div class='col-md-2'>
                    <label for='ic_tipo_num_documento_gridUsuario'>Tipo do Documento:&nbsp;</label>
                    <select class='form-control form-control-sm'  id='ic_tipo_num_documento_pesq' name='ic_tipo_num_documento_pesq'>
                        <option value=""></option>
                        <option value="1">Num Boleto</option>
                        <option value="2">Num NF</option>
                    </select>
                </div>
            </div>
            <div class="row">
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-2'>
                    <label for='tipos_operacao_pk'>Empresa:&nbsp;</label>
                    <select class='form-control form-control-sm'  id='empresa_lancamento_pk_pesq' name='empresa_lancamento_pk_pesq'/>
                    <option value=""></option>
                    </select>
                </div>
                <div class='col-md-2'>
                    <label for='bancos_pk'>Conta(s):&nbsp;</label>
                    <select class='form-control form-control-sm'  id='contas_lancamento_pk_pesq' name='contas_lancamento_pk_pesq' />
                    <option></option>
                    </select>
                </div>
                <div class='col-md-2'>
                    <label for='bancos_pk'>Status de Análise:&nbsp;</label>
                    <select class='form-control form-control-sm'  id='ic_status_analise_pesq' name='ic_status_analise_pesq' />
                    <option></option>
                    <option value="1">Não Analisado</option>
                    <option value="2">Aprovado Analista</option>
                    <option value="3">Aprovado Gestor</option>
                    <option value="4">Correção Solicitada</option>
                    <option value="6">Correção Feita</option>
                    <option value="7">Cancelado</option>
                    <option value="5">Recusado</option>
                    </select>
                </div>
            </div>
            <div class="row">
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-2'>
                    <label for='tipo_grupo_pk'>Grupo de Origem Lançamento:&nbsp;</label>
                    <select class='form-control form-control-sm'  id='tipo_grupo_lancamento_pk_pesq' name='tipo_grupo_lancamento_pk_pesq'/>
                    <option value=""></option>
                    <option value="1">Leads (Clientes)</option>
                    <option value="2">Colaboradores</option>
                    <option value="3">Fornecedores</option>
                    </select>
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento' class='recebido_de_pago_para'>Recebido de ? </label>
                    <select class='form-control form-control-sm'  id='grupo_lancamento_pk_pesq' name='grupo_lancamento_pk_pesq'/>
                    <option value=""></option>
                    </select>
                </div>
            </div>
            <div class='row'>
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento'>Data Cadastro  Inicío:&nbsp;</label>
                    <input type="text" class='form-control form-control-sm' maxlength="10" id="dt_cadastro_ini_lancamento_pesq" name="dt_cadastro_ini_lancamento_pesq"/>
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento' >Data Cadastro Fim</label>
                    <input type="text" class='form-control form-control-sm' maxlength="10" id="dt_cadastro_fim_lancamento_pesq" name="dt_cadastro_fim_lancamento_pesq"/>
                </div>
            </div>
            <div class='row'>
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento'>Data Faturamento  Inicío:&nbsp;</label>
                    <input type="text" class='form-control form-control-sm' maxlength="10" id="dt_faturamento_ini_lancamento_pesq" name="dt_faturamento_ini_lancamento_pesq"/>
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento' >Data Faturamento Fim</label>
                    <input type="text" class='form-control form-control-sm' maxlength="10" id="dt_faturamento_fim_lancamento_pesq" name="dt_faturamento_fim_lancamento_pesq"/>
                </div>
            </div>
            <div class='row'>
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento'>Data Vencimento  Inicío:&nbsp;</label>
                    <input type="text" class='form-control form-control-sm' maxlength="10" id="dt_vencimento_ini_lancamento_pesq" name="dt_vencimento_ini_lancamento_pesq"/>
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento' >Data Vencimento Fim</label>
                    <input type="text" class='form-control form-control-sm' maxlength="10" id="dt_vencimento_fim_lancamento_pesq" name="dt_vencimento_fim_lancamento_pesq"/>
                </div>
            </div>
            <div class='row'>
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento'>Data Pagamento  Inicío:&nbsp;</label>
                    <input type="text" class='form-control form-control-sm' maxlength="10" id="dt_pagamento_ini_lancamento_pesq" name="dt_pagamento_ini_lancamento_pesq"/>
                </div>
                <div class='col-md-2'>
                    <label for='vl_lancamento' >Data Pagamento Fim</label>
                    <input type="text" class='form-control form-control-sm' maxlength="10" id="dt_pagamento_fim_lancamento_pesq" name="dt_pagamento_fim_lancamento_pesq"/>
                </div>
            </div>
            <div class="row">
                <div class="col-md-8">
                    &nbsp;
                </div>
            </div>
            <div class="row">
                <div class="col-md-4">
                    &nbsp;
                </div>
                <div class="col-md-4" align="center">
                    <button type="button" class="btn btn-primary btn-sm" id="cmdPesquisarLancamentosUsuarios">Pesquisar</button>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <hr>
                </div>
            </div>
            <table class='table table-striped table-no-bordered  nowrap' style='width:100%' id='tblResultado' >
                <thead>
                <tr>
                    <th>#</th>
                    <th>Identificação do Lançamento</th>
                    <th>Dt Cadastro</th>
                    <th>Usuário de<br>Cadastro</th>
                    <th>Empresa</th>
                    <th>Conta</th>
                    <th>Dt Faturamento</th>
                    <th>Dt Vencimento</th>
                    <th>Dt Pagamento</th>
                    <th>Status</th>
                    <th>Tipo</th>
                    <th>Tipo Operação</th>
                    <th>Grupo de Lançamento</th>
                    <th>Recebido de / Pago Para</th>
                    <th>Metódo Pag.</th>
                    <th>Vl Lançamento</th>
                    <th>Vl Pendente</th>
                    <th>Status<br>Análise Financeira</th>
                    <th>Ação</th>
                </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
            <div class="row">
                <div class="col-md-12">
                    &nbsp;
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            &nbsp;
        </div>
    </div>
</main>
{% include('lancamento/financeiro_usuario_lancamento_cad_form.twig') %}
{% include('partials/financeiro_documento_historico_res_form.twig') %}
{% include('partials/financeiro_documentos_cad_form.twig') %}

{% endblock %}