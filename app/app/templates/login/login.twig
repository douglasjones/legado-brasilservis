{% extends "theme/base.login.twig" %}
{% set area = 'oauth' %}

{% block title %}
    Autenticação
{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block CSSfiles %}
    {{ parent() }}
    <link rel="stylesheet" href="/assets/css/local/authentication.css?v={{ config.VERSION_ID }}">
{% endblock %}

{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/js/global/oauth.js?v={{ config.VERSION_ID }}"></script>
{% endblock %}

{% block content %}
    <div class="form-content">
    <div class="form-items">
        <div class="px-3 py-4 p-md-5 p-xxl-5 mx-xxl-4">
            <div class="login-form py-2 py-md-0 mx-auto mx-lg-0">

                <!-- Logo no topo -->
                <div class="d-block text-center">
                    <img 
                        id="ds_img_cliente" 
                        alt="Logo" 
                        style="width: 70px; height: auto;"
                    >
                </div>

                <!-- Título -->
                <div class="d-block">
                    <h2 class="h2 mb-3 d-inline-block">Autenticação</h2>
                </div>

                <div class="position-relative">
                    <hr class="bg-gray-200 border-gray-200 opacity-100">
                </div>

                <!-- Formulário -->
                <form class="pt-2" id="authForm" method="POST" novalidate="novalidate" autocomplete="off">
                    <div class="mb-4 pb-md-2">
                        <label class="form-label form-label-lg">Login</label>
                        <div class="input-group-md">
                            <input type="text" class="form-control form-control-sm" placeholder="Login"
                                   name="login" id="login">
                        </div>
                    </div>
                    <div class="mb-4 pb-md-2">
                        <label class="form-label form-label-lg">Senha</label>
                        <div class="input-group-md">
                            <input type="password" class="form-control form-control-sm" id="password"
                                   placeholder="Senha" name="password">
                        </div>
                    </div>

                    <!-- Botão -->
                    <div class="d-grid">
                        <button type="button" class="btn btn-md btn-primary btn-auth">Entrar</button>
                    </div>
                </form>

                <!-- Footer visível somente no mobile -->
               <div class="d-block d-md-none mt-4 pt-3 border-top text-end text-nowrap" style="font-size: 12px; color: #333;">
                    <div class="d-flex justify-content-end align-items-center gap-2">
                        <span>© 2025 GPROS. Todos os direitos reservados.</span>
                        <img src="https://server.gpros.com.br/comercial/logos/logo_base.png"
                            alt="Logo"
                            style="height: 40px; width: auto;">
                    </div>
                </div>


            </div>
        </div>
    </div>
</div>

    {% include('login/modal/nova_senha.twig') %}
{% endblock %}
