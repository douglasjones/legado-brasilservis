{% block content %}
<div class="row">
    <div class="col-lg-12">
        <div class="row">
            <div class='col'>
                <h6 class="font-weight">Novo apontamento - <b>Disciplina</b></h6>
                <hr>
            </div>
            <div class="row" style="margin: 5px">
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-5'>
                    <label for='tipo_disciplina_pk'>Tipo de Disciplina:&nbsp;</label>
                    <select  name="tipo_disciplina_pk" class="form-control form-control-sm" id="tipo_disciplina_pk">
                        <option value=''></option>
                    </select>
                    <div class='row' id="alert_tipo_disciplina_pk" style="display:none">
                        <span aling="center" style="color: red">&nbsp;&nbsp;Por favor, informe o Tipo de Disciplina!</span>
                    </div>
                </div>
            </div>
            <div class="row" style="margin: 5px">
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-5'>
                    <div class='col'>
                    <label for='dt_disciplina'> Data da Disciplina: &nbsp; </label>
                    <input type='text' maxlength="10" class='form-control form-control-sm'  id='dt_disciplina' name='dt_disciplina' />
                    <div class='row' id="alert_dt_apontamento" style="display:none">
                        <span aling="center" style="color: red">Por favor, informe a Data da Disciplina!</span>
                    </div>
                </div>
                </div>
            </div>
            <div class="row" style="margin: 5px">
                <div class="col-md-3">
                    &nbsp;
                </div>
                <div class='col-md-5'>
                    <label for='obs'>Observação:&nbsp;</label>
                    <textarea cols="50"  id="obs" name="obs" class="form-control form-control-sm"></textarea>
                    <div class='row' id="alert_obs" style="display:none">
                        <span aling="center" style="color: red">&nbsp;&nbsp;Por favor, informe a Observação!</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}