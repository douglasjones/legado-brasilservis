{% block JSfiles %}
    <script src="/assets/js/local/financeiro_grid_extrato_mes.js?v=14"></script>
{% endblock %}
<div class="row">
    <div class="col-md-12">
        <h6 class="font-weight-bold" style= "color:#FF5403">Consulta de Receira(s)</h6>
        <hr style='height:1px; border:none; margin-top: 0px; margin-bottom: 0px;'>
    </div>
</div> 
<br>
<div class='row'>
    <div class='col-sm-1'>
        <div class="btn-group" role="group" aria-label="Button group with nested dropdown">
            <div class="btn-group" role="group">
                <select id="ds_ano" class="btn btn-primary btn-sm"></select>
            </div>
        </div> 
    </div>
    <div class='col-sm-6' align="left">
        <div class="btn-toolbar" role="toolbar" aria-label="Toolbar with button groups">
            <div class="btn-group mr-1" role="group" aria-label="First group">
              <button type="button" class="btn btn-primary btn-sm" id="ic_jan">JAN</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_fev">FEV</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_mar">MAR</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_abr">ABR</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_mai">MAI</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_jun">JUN</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_jul">JUL</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_ago">AGO</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_set">SET</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_out">OUT</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_nov">NOV</button>
              <button type="button" class="btn btn-primary btn-sm" id="ic_dez">DEZ</button>
              <input type="hidden" id="ic_mes" value="ic_mes" >                                      
            </div>
        </div>  
    </div>
</div>
<br>
<div class='row'>   
    <div class='col-sm-4'>
        <label for='bancos_pk'>Empresa(s):&nbsp;</label>
        <select class='form-control form-control-sm'  id='empresas_pk_extrato_mes' name='empresas_pk_extrato_mes' />
            <option></option>
        </select>
    </div>
    <div class='col-sm-4'>
        <label for='bancos_pk'>Conta(s):&nbsp;</label>
        <select class='form-control form-control-sm'  id='contas_pk_extrato_mes' name='contas_pk_extrato_mes' />
            <option></option>
        </select> 
    </div>
</div>
<br>
<div id='extrato_mes'>
    <div class='overflow-auto' style='height:400px;overflow-y: scroll;' >
        <table class='table table-striped table-bordered ' style='width:100%' id='tblExtrato' >
            <thead style='position: sticky; top: 0px; background-color: white;'>
                <tr>
                    <th width='5' align='center'><font style='font-size: 15px'><b>#</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Identificação do Lançamento</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Dt. Cadastro</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Usuário Cadastro</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Dt. Faturamento</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Dt. Vencimento</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Dt. Pagamento</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Tipo</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Tipo Operação</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Grupo do Lançamento</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Recebido de/Pago Para</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Metódo Pag.</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Vl. Receita</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Vl. Despesa</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Vl. Saldo</b></font></th>
                    <th align='center'><font style='font-size: 15px'><b>Ação</b></font></th>
                </tr>
            </thead>
            <tfoot style='position: sticky; bottom: 0px; background-color: white;'>
                <tr>
                    <td width='100' colspan=11 >&nbsp;</td>
                    <td width='100' ><b>Total R$<b/></td>
                    <td align='center' id='totalExtratoReceita'></td>
                    <td align='center' id='totalExtratoDespesa'></td>
                    <td align='center' id='totalExtratoSaldo'></td>
                    <td align='center'>&nbsp;</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>