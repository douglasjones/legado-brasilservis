                                                <input type="text" class="form-control form-control-sm" id="ds_pin" required="true">
                                            </div>            
                                        </div>      
                                        <p>
                                        <div class="row">
                                            <div class="col-md-4">
                                                &nbsp;
                                            </div>
                                            <div class='col-md-4'>
                                                <label for="ds_pin">R.E:&nbsp;</label>
                                                <input type="text" class="form-control form-control-sm" id="ds_re" required="true">
                                            </div>
                                        </div>  
                                        
                                        <div class="row">
                                           <div class="col-md-4">
                                                &nbsp;
                                            </div>
                                            <div class="col-md-4">
