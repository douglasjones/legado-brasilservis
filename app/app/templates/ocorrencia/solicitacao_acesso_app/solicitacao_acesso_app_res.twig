                                        <div class="row">
                                            <div class="col-md-4">
                                                &nbsp;
                                            </div>
                                            <div class='col-md-4'>
                                                <label for='ds_tel'>Colaboradores</label>
                                                <select class='form-control form-control-sm chzn-select'  id='colaboradores_pk' name='colaboradores_pk'>
