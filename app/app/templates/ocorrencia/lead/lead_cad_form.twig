                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal" onclick="fecharModalContato()">Fechar</button>
                            <button type="submit" class="btn btn-primary btn-sm" id="cmdEnviarContato"  name="cmdEnviarContato">Salvar</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

