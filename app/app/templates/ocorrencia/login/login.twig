{% extends "theme/base.login.twig" %}
{% set area = 'oauth' %}

{% block title %}
    Autenticação
{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block CSSfiles %}
    {{ parent() }}
    <link rel="stylesheet" href="/assets/css/local/authentication.css?v={{ config.VERSION_ID }}">
{% endblock %}

{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/js/global/oauth.js?v={{ config.VERSION_ID }}"></script>
{% endblock %}

{% block content %}
    <div style="max-width: 800px;max-height: 100px;margin: 25vh auto;">
        <div style="background: #ffffff; padding: 10px 30px 10px;border-radius: 0px;box-shadow: 0 0 1.8rem rgba(0, 0, 0, 0.25);z-index: -1;">
            <div class="row">
                <div class="col-lg-6" style="height:5px;back width:23rem; margin-top:6em; text-align: center;" >
  
                    <img id="ds_img_cliente" style="width: 280px" >

                </div>
                <div class="col-lg-6" >
                    <div class="p-4">
                        <div>
                            <h1 class="h4 text-gray-900 mb-4 text-center">Bem Vindo!</h1>
                        </div>
                        <form class="pt-2" id="authForm" novalidate="novalidate" autocomplete="off" onsubmit="return false;">
                            <div class="form-group">
                                <input type="text" id="login" class="form-control form-control-lg" placeholder="Insira Login..." name="login" style='border-radius:25px;border:3px solid #FF5403;'>
                            </div>
                            <p></p>                            
                            <div class="form-group">
                                <input type="password" class="form-control form-control-lg" id="password" placeholder="Password" name="password" style='border-radius:25px;border:3px solid #FF5403;'>
                            </div>
                             <p></p>    
                            <button style="width: 310px;border-radius:25px" class="btn btn-primary btn-block btn-auth" >Login</button>
                            <hr>
                            <div class="row">
                                <div class="col" align="right" >
                                    <img width="80" height="20" src="https://gepros.com.br/comercial/condominios/img/nlogo.png" >
                                </div>
                            </div>
                            <div class="row">
                                <div class="col" align="right" style="font-size:12px;color:#FF5403">
                                    <label><span id="ds_versao"></span></label>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% include('login/modal/nova_senha.twig') %}
{% endblock %}
