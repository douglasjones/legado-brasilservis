{% set area = 'financeiro' %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v={{ JSversion }}"></script>
    <script>
        let faturamento_modulo = permissao("faturamento_modulo", "cons");
        if(faturamento_modulo.status != true){
            $('#faturamento').hide();
        }

        let teto_gastos_modulo = permissao("teto_gastos_modulo", "cons");
        if(teto_gastos_modulo.status != true){
            $('#teto_gasto').hide();
        }

        let analise_financeira_modulo = permissao("analise_financeira_modulo", "cons");
        if(analise_financeira_modulo.status != true){
            $('#analise_financeira').hide();
        }

        let financeiro_lancamentos_usuarios_modulo = permissao("financeiro_lancamentos_usuarios_modulo", "cons");
        if(financeiro_lancamentos_usuarios_modulo.status != true){
            $('#financeiro_lancamentos_usuarios_modulo').hide();
        }

        let financeiro_controle_moodulo = permissao("financeiro_controle_moodulo", "cons");
        if(financeiro_controle_moodulo.status != true){
            $('#financeiro').hide();
        }


    </script>
{% endblock %}
